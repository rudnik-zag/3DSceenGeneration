DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tribalai3d?schema=public
AUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9100
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=artifacts
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SPLAT_RUNTIME=auto
NEXT_PUBLIC_SPARK_ENABLED=true
SAM2_REPO_ROOT=/absolute/path/to/models/sam2
SAM2_CHECKPOINT=/absolute/path/to/models/sam2/checkpoints/sam2.1_hiera_large.pt
SAM2_TOOLS_DIR=/absolute/path/to/models/sam2/tools
LOCAL_STORAGE_ROOT=.local-storage
SAM2_EXECUTION_MODE=real
SAM2_ALLOW_MOCK_FALLBACK=true
SAM2_USE_CONDA=true
SAM2_CONDA_COMMAND=conda
SAM2_CONDA_ENV=sam2

SAM3D_REPO_ROOT=/absolute/path/to/models/sam-3d-objects
SAM3D_WEB_SCRIPT=inference_for_webapp_per_object.py
SAM3D_EXECUTION_MODE=real
SAM3D_ALLOW_MOCK_FALLBACK=true
SAM3D_USE_CONDA=true
SAM3D_CONDA_COMMAND=conda
SAM3D_CONDA_ENV=sam3d-objects

# Optional: real GroundingDINO runtime (worker will call conda run)
GROUNDING_DINO_CONDA_COMMAND=conda
GROUNDING_DINO_CONDA_ENV=grounding_dino
GROUNDING_DINO_WEB_SCRIPT=demo/inference_for_webapp.py
GROUNDING_DINO_CONFIG_RELATIVE=groundingdino/config/GroundingDINO_SwinT_OGC.py
GROUNDING_DINO_CHECKPOINT_RELATIVE=weights/groundingdino_swint_ogc.pth
GROUNDING_DINO_CPU_ONLY=false

# Security / rate limit
AUTH_LOGIN_LIMIT=6
AUTH_LOGIN_WINDOW_SEC=60
AUTH_REGISTER_LIMIT=4
AUTH_REGISTER_WINDOW_SEC=60
RUN_CREATE_LIMIT=20
RUN_CREATE_WINDOW_SEC=60
UPLOAD_INIT_LIMIT=60
UPLOAD_INIT_WINDOW_SEC=60
SIGNED_URL_LIMIT=120
SIGNED_URL_WINDOW_SEC=60
SIGNED_URL_TTL_SEC=120
SIGNED_URL_MAX_TTL_SEC=300

# Billing / subscriptions / token packs
BILLING_ENFORCEMENT_ENABLED=true
BILLING_CHECKOUT_LIMIT=20
BILLING_CHECKOUT_WINDOW_SEC=60
BILLING_WEBHOOK_LIMIT=240
BILLING_WEBHOOK_WINDOW_SEC=60
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FREE_MONTHLY=
STRIPE_PRICE_CREATOR_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_STUDIO_MONTHLY=
STRIPE_PRICE_TOKEN_PACK_STARTER=
STRIPE_PRICE_TOKEN_PACK_GROWTH=
STRIPE_PRICE_TOKEN_PACK_SCALE=
