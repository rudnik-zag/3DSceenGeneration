generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RunStatus {
  queued
  running
  success
  error
  canceled
}

enum ArtifactKind {
  image
  mask
  json
  mesh_glb
  point_ply
  splat_ksplat
}

enum ProjectRole {
  owner
  editor
  viewer
}

enum SubscriptionPlan {
  Free
  Creator
  Pro
  Studio
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  incomplete
  incomplete_expired
}

enum TokenTransactionType {
  credit
  debit
  refund
  monthly_reset
}

enum TokenTransactionSource {
  subscription
  token_pack
  usage
  admin
}

enum UsageEventStatus {
  reserved
  completed
  failed
  canceled
}

model User {
  id             String          @id @default(cuid())
  email          String?         @unique
  passwordHash   String?
  name           String?
  image          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  sessions       Session[]
  authenticators Authenticator[]
  ownedProjects  Project[]       @relation("ProjectOwner")
  projectMembers ProjectMember[]
  graphsCreated  Graph[]         @relation("GraphCreator")
  runsCreated    Run[]           @relation("RunCreator")
  artifactsOwned Artifact[]      @relation("ArtifactOwner")
  auditLogs      AuditLog[]
  subscription   Subscription?
  tokenWallet    TokenWallet?
  tokenTxns      TokenTransaction[]
  usageEvents    UsageEvent[]
  runEvents      RunEvent[]
  runSteps       RunStep[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model Project {
  id           String          @id @default(cuid())
  ownerId      String          @map("userId")
  name         String
  slug         String?         @unique
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  owner        User            @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      ProjectMember[]
  graphs       Graph[]
  runs         Run[]
  artifacts    Artifact[]
  uploadAssets UploadAsset[]
  cacheEntries CacheEntry[]
  auditLogs    AuditLog[]
  tokenTxns    TokenTransaction[]
  usageEvents  UsageEvent[]
  runEvents    RunEvent[]
  runSteps     RunStep[]
  runCounter   ProjectRunCounter?

  @@index([ownerId])
}

model ProjectRunCounter {
  projectId     String   @id
  nextRunNumber Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(viewer)
  createdAt DateTime    @default(now())
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId, role])
  @@index([userId])
}

model UploadAsset {
  id         String   @id @default(cuid())
  projectId  String
  nodeId     String?
  category   String   @default("input.image")
  fileName   String
  mimeType   String
  byteSize   Int
  storageKey String   @unique
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([projectId, category])
}

model Graph {
  id        String   @id @default(cuid())
  projectId String
  createdBy String?
  name      String
  graphJson Json
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator   User?    @relation("GraphCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  runs      Run[]
  runEvents RunEvent[]
  runSteps  RunStep[]

  @@index([projectId])
  @@index([projectId, version])
  @@index([createdBy])
}

model Run {
  id         String     @id @default(cuid())
  projectId  String
  graphId    String
  runNumber  Int
  createdBy  String?
  status     RunStatus  @default(queued)
  startedAt  DateTime?
  finishedAt DateTime?
  logs       String     @default("")
  progress   Int        @default(0)
  createdAt  DateTime   @default(now())
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  graph      Graph      @relation(fields: [graphId], references: [id], onDelete: Restrict)
  creator    User?      @relation("RunCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  artifacts  Artifact[]
  tokenTxns  TokenTransaction[]
  usageEvents UsageEvent[]
  events      RunEvent[]
  steps       RunStep[]

  @@index([projectId])
  @@unique([projectId, runNumber])
  @@index([graphId])
  @@index([status])
  @@index([createdBy])
}

model RunEvent {
  id         String    @id @default(cuid())
  runId      String
  projectId  String
  graphId    String
  userId     String?
  eventType  String
  status     RunStatus?
  nodeId     String?
  nodeType   String?
  message    String?
  metadata   Json?
  createdAt  DateTime  @default(now())
  run        Run       @relation(fields: [runId], references: [id], onDelete: Cascade)
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  graph      Graph     @relation(fields: [graphId], references: [id], onDelete: Cascade)
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([runId, createdAt])
  @@index([projectId, createdAt])
  @@index([graphId, createdAt])
  @@index([userId, createdAt])
  @@index([eventType, createdAt])
}

model RunStep {
  id            String    @id @default(cuid())
  runId         String
  projectId     String
  graphId       String
  userId        String?
  nodeId        String
  nodeType      String
  stepCode      String?
  stepLabel     String?
  attempt       Int      @default(1)
  sequence      Int
  status        RunStatus @default(running)
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  durationMs    Int?
  cacheHit      Boolean?
  inputSummary  String?
  outputSummary String?
  errorMessage  String?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  run           Run       @relation(fields: [runId], references: [id], onDelete: Cascade)
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  graph         Graph     @relation(fields: [graphId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([runId, sequence])
  @@index([runId, status, sequence])
  @@index([runId, stepCode, sequence])
  @@index([projectId, createdAt])
  @@index([graphId, createdAt])
  @@index([userId, createdAt])
  @@index([nodeId, createdAt])
}

model Artifact {
  id                String       @id @default(cuid())
  runId             String
  projectId         String
  ownerId           String?
  nodeId            String
  kind              ArtifactKind
  mimeType          String
  byteSize          Int
  hash              String
  storageKey        String
  previewStorageKey String?
  meta              Json?
  createdAt         DateTime     @default(now())
  run               Run          @relation(fields: [runId], references: [id], onDelete: Cascade)
  project           Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner             User?        @relation("ArtifactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  cacheEntries      CacheEntry[]

  @@index([runId])
  @@index([projectId])
  @@index([projectId, nodeId])
  @@index([ownerId])
}

model CacheEntry {
  id         String   @id @default(cuid())
  projectId  String
  cacheKey   String   @unique
  artifactId String
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifact   Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([artifactId])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  resourceType String
  resourceId   String?
  projectId    String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@index([action, createdAt])
}

model Subscription {
  id                    String             @id @default(cuid())
  userId                String             @unique
  plan                  SubscriptionPlan   @default(Free)
  status                SubscriptionStatus @default(active)
  billingProvider       String?
  billingCustomerId     String?
  billingSubscriptionId String?            @unique
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([plan, status])
}

model TokenWallet {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  monthlyTokensRemaining   Int      @default(0)
  purchasedTokensRemaining Int      @default(0)
  totalTokensUsed          Int      @default(0)
  monthlyAllowance         Int      @default(0)
  periodStart              DateTime?
  periodEnd                DateTime?
  updatedAt                DateTime @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TokenTransaction {
  id          String                 @id @default(cuid())
  userId      String
  projectId   String?
  runId       String?
  type        TokenTransactionType
  source      TokenTransactionSource
  amount      Int
  description String
  metadata    Json?
  createdAt   DateTime               @default(now())
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  run         Run?                   @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@index([runId, createdAt])
  @@index([type, source, createdAt])
}

model UsageEvent {
  id                 String           @id @default(cuid())
  userId             String
  projectId          String
  runId              String?          @unique
  featureKey         String
  estimatedTokenCost Int
  actualTokenCost    Int?
  status             UsageEventStatus @default(reserved)
  metadata           Json?
  createdAt          DateTime         @default(now())
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  project            Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  run                Run?             @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@index([status, createdAt])
}

model StripeWebhookEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  eventType String
  processed Boolean  @default(false)
  payload   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventType, createdAt])
  @@index([processed, createdAt])
}
